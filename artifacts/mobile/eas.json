{
  "cli": {
    "version": ">= 20.1.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "prebuildCommand": "node ../../patch-native-modules.js"
    },
    "preview": {
      "distribution": "internal",
      "prebuildCommand": "node ../../patch-native-modules.js"
    },
    "production": {
      "autoIncrement": true,
      "prebuildCommand": "node ../../patch-native-modules.js",
      "env": {
        "EAS_BUILD_NO_EXPO_GO_WARNING": "true"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
