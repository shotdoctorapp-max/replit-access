{
  "expo": {
    "name": "Shot Doctor",
    "slug": "shot-doctor",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "shotdoctor",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#000000",
    "splash": {
      "image": "./assets/images/splash-bg.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.shotdoctor.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "package": "com.shotdoctor.app"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-video",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Shot Doctor to access your videos to analyze your shooting form.",
          "cameraPermission": "Allow Shot Doctor to record video to analyze your shooting form."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow Shot Doctor to access your photo library to download iCloud videos for analysis.",
          "savePhotosPermission": "Allow Shot Doctor to save videos to your photo library.",
          "isAccessMediaLocationEnabled": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
